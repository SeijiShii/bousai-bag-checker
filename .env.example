# 持ち出し袋チェッカー 環境変数 (ダミー値、コミット可)。実値は .env.local (gitignore 済) へ。
# サーバー専用 env は VITE_ プレフィックスを付けない (クライアントバンドルに含めない、SEC-005)。

# --- DB (Neon, サーバー専用) ---
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# --- service-hub 連携 (O48、サーバー専用) ---
SERVICE_INFO_TOKEN=change-me-shared-secret

# --- フロントエンド Backend 選択 (dev のみ) ---
# memory(既定/keyless) | http(/api を叩く、api 結合確認用)
VITE_BACKEND=memory

# === 以下は release (P4.7) で実値を .env.local / デプロイ先 env に設定 ===

# --- 認証 (Clerk) ---
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- 投げ銭 (Stripe、サーバー専用) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- メール (Resend、サーバー専用) ---
RESEND_API_KEY=re_xxx

# --- 写真ストレージ (Cloudflare R2、サーバー専用、任意) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bousai-bag-photos

# --- エラー監視 (Sentry) ---
VITE_SENTRY_DSN=
SENTRY_DSN=

# --- Cron 保護 (Vercel Cron → /api/cron/expiry-check) ---
CRON_SECRET=change-me-cron-secret

# --- レート制限 (Upstash Redis、公開 EP、任意) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
